import torchvision
import pandas as pd

#MASK
mask_model = torchvision.models.detection.maskrcnn_resnet50_fpn(pretrained=True)
mask_model.eval().cuda()

def get_mask(image):
    img = torch.tensor(image/255.).permute(2,0,1).float().cuda()
    with torch.no_grad():
        pred = mask_model([img])[0]

    if len(pred['masks']) == 0:
        return None

    mask = pred['masks'][0,0].cpu().numpy()
    return (mask > 0.5).astype(np.uint8)

#DPT Hybrid
model_type = "dpt_hybrid"
#midas = torch.hub.load("intel-isl/MiDaS", model_type)
midas = torch.hub.load("intel-isl/MiDaS", "DPT_Hybrid")
midas.cuda().eval()

transforms = torch.hub.load("intel-isl/MiDaS", "transforms")
transform = transforms.dpt_transform

def get_depth(image):
    input_batch = transform(image).cuda()

    with torch.no_grad():
        prediction = midas(input_batch)
        prediction = torch.nn.functional.interpolate(
            prediction.unsqueeze(1),
            size=image.shape[:2],
            mode="bicubic",
            align_corners=False,
        ).squeeze()

    return prediction.cpu().numpy()

def estimate_volume(mask, depth):
    if mask is None:
        return 0

    volume = np.sum(depth * mask)
    return volume

