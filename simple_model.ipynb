    print(split, "exists:", os.path.exists(path))

SRC = "food-101" # This is the main directory containing train/val/test splits
DEST = "data_small"

# Correctly get the list of food categories
# Assuming food categories are subdirectories within 'food-101/train'
all_food_categories = os.listdir(os.path.join(SRC, "train"))
random.shuffle(all_food_categories)

# Choose subset (20 or all 101)
selected_food_categories = all_food_categories[:20]  # Food-20 version

# Create destination directories for each split and selected food category
for split in ["train", "val", "test"]:
    for food_cls_name in selected_food_categories:
        os.makedirs(f"{DEST}/{split}/{food_cls_name}", exist_ok=True)

# Copy images for each selected food category
for food_cls_name in selected_food_categories:
    all_images_for_current_category = []

    # Collect all image paths for the current food category from all original splits
    for original_split in ["train", "val", "test"]:
        original_class_path = os.path.join(SRC, original_split, food_cls_name)
        if os.path.exists(original_class_path):
            image_filenames = os.listdir(original_class_path)
            # Create full paths for source files
            full_image_paths = [os.path.join(original_class_path, fname) for fname in image_filenames]
            all_images_for_current_category.extend(full_image_paths)

    random.shuffle(all_images_for_current_category)

    # Define the number of images for new train, val, test splits in DEST
    num_train_target = 140
    num_val_target = 30
    num_test_target = 30

    # Distribute the collected images into the new splits
    train_images = all_images_for_current_category[:num_train_target]
    val_images = all_images_for_current_category[num_train_target : num_train_target + num_val_target]
    test_images = all_images_for_current_category[num_train_target + num_val_target : num_train_target + num_val_target + num_test_target]

    # Copy images to their respective new destination folders
    for img_path in train_images:
        dest_path = os.path.join(DEST, "train", food_cls_name, os.path.basename(img_path))
        shutil.copy(img_path, dest_path)
    for img_path in val_images:
        dest_path = os.path.join(DEST, "val", food_cls_name, os.path.basename(img_path))
        shutil.copy(img_path, dest_path)
    for img_path in test_images:
        dest_path = os.path.join(DEST, "test", food_cls_name, os.path.basename(img_path))
        shutil.copy(img_path, dest_path)

#--------------------
#TRAINING and METRICS
#--------------------
model = YOLO("yolo11s-cls.pt")  # pretrained
model.train(
    data="data_small",
    epochs=40,
    imgsz=256,
    batch=32
)

metrics = model.val()
print(metrics)

