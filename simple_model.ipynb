import pandas as pd
import matplotlib.pyplot as plt
import os

# Find the latest training results file
results_csv = "runs/classify/train/results.csv"

if not os.path.exists(results_csv):
    # If train2, train3, etc. exists
    classify_dir = "runs/classify"

    train_folders = sorted([
        d for d in os.listdir(classify_dir)
        if d.startswith("train")
    ])

    latest_train = train_folders[-1]
    results_csv = os.path.join(classify_dir, latest_train, "results.csv")

print("Using:", results_csv)

# Load training history
df = pd.read_csv(results_csv)

# Remove extra spaces from column names
df.columns = df.columns.str.strip()

print(df.columns.tolist())  # useful for debugging

# ============================================================
# Create 2x2 figure
# ============================================================

fig, axes = plt.subplots(2, 2, figsize=(14, 10))

# ------------------------------------------------------------
# Train Loss
# ------------------------------------------------------------
axes[0, 0].plot(
    df["epoch"],
    df["train/loss"],
    linewidth=2
)

axes[0, 0].set_title("Training Loss")
axes[0, 0].set_xlabel("Epoch")
axes[0, 0].set_ylabel("Loss")
axes[0, 0].grid(True)

# ------------------------------------------------------------
# Validation Loss
# ------------------------------------------------------------
axes[0, 1].plot(
    df["epoch"],
    df["val/loss"],
    linewidth=2,
    color="orange"
)

axes[0, 1].set_title("Validation Loss")
axes[0, 1].set_xlabel("Epoch")
axes[0, 1].set_ylabel("Loss")
axes[0, 1].grid(True)

# ------------------------------------------------------------
# Top-1 Accuracy
# ------------------------------------------------------------
axes[1, 0].plot(
    df["epoch"],
    df["metrics/accuracy_top1"],
    linewidth=2,
    color="green"
)

axes[1, 0].set_title("Top-1 Accuracy")
axes[1, 0].set_xlabel("Epoch")
axes[1, 0].set_ylabel("Accuracy")
axes[1, 0].grid(True)

# ------------------------------------------------------------
# Top-5 Accuracy
# ------------------------------------------------------------
axes[1, 1].plot(
    df["epoch"],
    df["metrics/accuracy_top5"],
    linewidth=2,
    color="red"
)

axes[1, 1].set_title("Top-5 Accuracy")
axes[1, 1].set_xlabel("Epoch")
axes[1, 1].set_ylabel("Accuracy")
axes[1, 1].grid(True)

plt.tight_layout()
plt.show()
